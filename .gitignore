# ============================================================
# ~/.claude/ sync — exclude secrets, machine-specific state,
# caches, logs, and conversation history. Track config, skills,
# plugin blocklist, and memory.
# ============================================================

# --- Secrets (NEVER commit) ---
.credentials.json
config.json
*.pem
*.key

# --- Machine-specific overrides ---
# settings.local.json is the canonical place for per-machine config
# (paths, OS-specific permissions, local env vars). Keep it local.
settings.local.json

# --- Stale settings backups ---
settings.json.bak
settings.json.orig
settings.json.pre-*
*.backup.*/
backups/

# --- Logs & telemetry ---
*.log
bash-commands.log
cost-tracker.log
history.jsonl
stats-cache.json
telemetry/
usage-data/
metrics/
homunculus/

# --- Caches & transient state ---
cache/
downloads/
paste-cache/
file-history/
ide/
session-data/
session-env/
sessions/
shell-snapshots/
tasks/
.buddy-reroll.json
project-config.json
security_warnings_state_*.json
mcp-needs-auth-cache.json

# --- Plugins: only blocklist is tracked ---
# installed_plugins.json and known_marketplaces.json are rewritten at
# runtime with per-machine timestamps and Windows-style install paths,
# so tracking them causes churn. Source-of-truth:
#   - which plugins to enable → settings.json (enabledPlugins)
#   - marketplace sources → settings.json (extraKnownMarketplaces),
#     plus the built-in claude-plugins-official marketplace
# Marketplace git clones are re-fetched on each machine.
plugins/cache/
plugins/data/
plugins/marketplaces/
plugins/install-counts-cache.json
plugins/installed_plugins.json
plugins/known_marketplaces.json

# --- Projects: ignore entirely ---
# Conversation history, todos, shell-snapshots, and auto-memory are all
# per-machine/per-session state. Not worth syncing — each machine's
# Claude Code maintains its own projects/ content.
projects/

# --- Editor / OS ---
.DS_Store
Thumbs.db
*.swp
*~
